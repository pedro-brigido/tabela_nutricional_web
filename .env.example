# Ambiente: development | testing | production
FLASK_ENV=development

# Entry point da aplicação (factory em app/__init__.py)
FLASK_APP=wsgi:app

SECRET_KEY=DEV
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-seu-segredo

# Stripe (Checkout + Billing + Webhooks)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_FLOW_START=price_...
STRIPE_PRICE_ID_FLOW_PRO=price_...
STRIPE_PRICE_ID_FLOW_STUDIO=price_...

# Diretório para dados (app.db, subscribers.db). Opcional; padrão: ./data
# DATA_DIR=./data

# Banco (opcional; padrão: sqlite em DATA_DIR)
# DATABASE_URL=sqlite:///./data/app.db

# =============================================================================
# OPENAI / CHATBOT DE SUPORTE IA
# =============================================================================
# Se OPENAI_API_KEY estiver preenchida, o chatbot pode ser habilitado automaticamente.
# Defina CHATBOT_ENABLED=false para desligar explicitamente em qualquer ambiente.
OPENAI_API_KEY=
# CHATBOT_ENABLED=true
# CHATBOT_MODEL=gpt-4o-mini
# CHATBOT_FALLBACK_MODEL=gpt-5-mini
# CHATBOT_EMBEDDING_MODEL=text-embedding-3-small
# CHATBOT_MODERATION_MODEL=omni-moderation-latest
# CHATBOT_COOKIE_NAME=terracota_chat_anon
# CHATBOT_ANON_RETENTION_DAYS=30
# CHATBOT_AUTH_RETENTION_DAYS=180
# CHATBOT_MAX_TURNS_BEFORE_SUMMARY=6
# CHATBOT_OPENAI_TIMEOUT_SECONDS=20
# CHATBOT_OPENAI_COOLDOWN_SECONDS=180

# =============================================================================
# CONFIGURAÇÃO DE EMAIL - SMTP (OBRIGATÓRIO PARA ENVIO)
# =============================================================================
# Se você deseja que a aplicação envie emails com relatórios,
# configure todas as variáveis abaixo.

# Servidor SMTP
# Gmail: smtp.gmail.com
# Outlook: smtp.office365.com
# SendGrid: smtp.sendgrid.net
SMTP_HOST=smtp.gmail.com

# Porta do servidor SMTP
# TLS/STARTTLS: 587 (recomendado)
# SSL: 465
SMTP_PORT=587

# Usuário SMTP (geralmente seu email)
SMTP_USER=comercial@terracotabpo.com

# Senha SMTP
# Para Gmail: Use App Password (não senha normal)
# Como obter App Password: https://myaccount.google.com/apppasswords
# Para outros provedores: Use senha da conta ou senha de aplicativo
SMTP_PASSWORD=seu-app-password-ou-senha

# Usar TLS para conexão SMTP (sempre true em produção)
SMTP_USE_TLS=true

# Email remetente (aparecerá como "De:")
EMAIL_FROM=comercial@terracotabpo.com

# Email que receberá notificação de nova submissão na newsletter
NEWSLETTER_NOTIFY_EMAIL=comercial@terracotabpo.com
