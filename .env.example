SECRET_KEY="DEV"
GOOGLE_CLIENT_ID="seu-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-seu-segredo"

# =============================================================================
# CONFIGURAÇÃO DE EMAIL - SMTP (OBRIGATÓRIO PARA ENVIO)
# =============================================================================
# Se você deseja que a aplicação envie emails com relatórios,
# configure todas as variáveis abaixo.

# Servidor SMTP
# Gmail: smtp.gmail.com
# Outlook: smtp.office365.com
# SendGrid: smtp.sendgrid.net
SMTP_HOST=smtp.gmail.com

# Porta do servidor SMTP
# TLS/STARTTLS: 587 (recomendado)
# SSL: 465
SMTP_PORT=587

# Usuário SMTP (geralmente seu email)
SMTP_USER=comercial@terracotabpo.com

# Senha SMTP
# Para Gmail: Use App Password (não senha normal)
# Como obter App Password: https://myaccount.google.com/apppasswords
# Para outros provedores: Use senha da conta ou senha de aplicativo
SMTP_PASSWORD=seu-app-password-ou-senha

# Usar TLS para conexão SMTP (sempre true em produção)
SMTP_USE_TLS=true

# Email remetente (aparecerá como "De:")
EMAIL_FROM=comercial@terracotabpo.com

# Email que receberá notificação de nova submissão na newsletter
NEWSLETTER_NOTIFY_EMAIL=comercial@terracotabpo.com